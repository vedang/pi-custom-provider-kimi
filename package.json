{
  "name": "pi-custom-provider-kimi",
  "version": "0.1.0",
  "description": "Register Kimi K2 models as a pi provider.",
  "type": "module",
  "keywords": ["pi-package", "pi", "extension", "provider", "kimi", "moonshot"],
  "pi": {
    "extensions": ["./src/index.ts"],
    "image": "https://raw.githubusercontent.com/vedang/pi-custom-provider-kimi/main/images/banner.png"
  },
  "files": ["src/index.ts", "src/core.ts"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc --noEmit --watch --preserveWatchOutput",
    "test": "vitest run --config vitest.config.unit.ts",
    "test:watch": "vitest --config vitest.config.unit.ts",
    "test:coverage": "vitest run --config vitest.config.unit.ts --coverage"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@earendil-works/pi-ai": "0.80.6",
    "@earendil-works/pi-coding-agent": "0.80.6",
    "@types/node": "^24.12.0",
    "@vitest/coverage-v8": "^3.2.4",
    "jscpd": "^4.0.8",
    "knip": "^5.86.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
